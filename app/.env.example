# Copy this file to .env.local and fill in your Supabase project values.
# (.env.local is git-ignored — your keys never get committed.)
#
# Find these in Supabase: Project Settings → API.
# Use the PUBLISHABLE key (safe for the browser), NOT the service_role key.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
